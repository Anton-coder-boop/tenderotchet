        {name:"АО \"АВИЛОН АВТОМОБИЛЬНАЯ ГРУППА\"", sum:51940000, region:"Москва Город", category:"Автотранспорт легковой, автобусы", status:"Исполнение", date:"2026-02-16", brandHint:"BMW, Mercedes, Haval", customer:"ГОСУДАРСТВЕННАЯ ФЕЛЬДЪЕГЕРСКАЯ СЛУЖБА РОССИЙСКОЙ ФЕДЕРАЦИИ"},
        {name:"АО \"РОЛЬФ\"", sum:50615654.81, region:"Москва Город", category:"Автотранспорт легковой, автобусы", status:"Контракт заключен", date:"2026-02-24", brandHint:"Haval, Kia, Geely", customer:"ГОСУДАРСТВЕННОЕ БЮДЖЕТНОЕ УЧРЕЖДЕНИЕ ГОРОДА МОСКВЫ \"АВТОМОБИЛЬНЫЕ ДОРОГИ\""},
        {name:"АО \"ЛАДА-СЕРВИС\"", sum:24412740, region:"Самарская Область", category:"Автотранспорт легковой, автобусы", status:"Исполнение", date:"2026-03-24", brandHint:"LADA Granta, Vesta", customer:"МИНИСТЕРСТВО СОЦИАЛЬНО-ДЕМОГРАФИЧЕСКОЙ И СЕМЕЙНОЙ ПОЛИТИКИ САМАРСКОЙ ОБЛАСТИ"},
        {name:"АО \"ЛАДА-СЕРВИС\"", sum:16333800.03, region:"Луганская Народная Республика", category:"Автотранспорт легковой, автобусы", status:"Контракт заключен", date:"2026-04-03", brandHint:"LADA", customer:"ОТДЕЛЕНИЕ СФР ПО ЛУГАНСКОЙ НАРОДНОЙ РЕСПУБЛИКЕ"},
        {name:"АО \"ЛАДА-СЕРВИС\"", sum:14588799.96, region:"Краснодарский Край", category:"Спецтранспорт", status:"Исполнение", date:"2026-03-23", brandHint:"LADA", customer:"ОТДЕЛЕНИЕ СФР ПО КРАСНОДАРСКОМУ КРАЮ"},
        {name:"АО \"ЛАДА-СЕРВИС\"", sum:10006400.88, region:"Кировская Область", category:"Спецтранспорт", status:"Исполнение", date:"2026-03-31", brandHint:"LADA", customer:"ОТДЕЛЕНИЕ СФР ПО КИРОВСКОЙ ОБЛАСТИ"},
        {name:"ООО \"ПРОФАВТО\"", sum:11121000, region:"Тверская Область", category:"Спецтранспорт", status:"Исполнение", date:"2026-03-31", brandHint:"Скорая помощь", customer:"ФГБУЗ МСЧ №57 ФМБА"},
        {name:"ООО \"ПРОФАВТО\"", sum:11121000, region:"Томская Область", category:"Спецтранспорт", status:"Исполнение", date:"2026-03-31", brandHint:"Скорая помощь", customer:"ФГБУ СИБИРСКИЙ ФНКЦ ФМБА"},
        {name:"ООО \"ПРОФАВТО\"", sum:11121000, region:"Москва Город", category:"Спецтранспорт", status:"Исполнение", date:"2026-03-31", brandHint:"Скорая помощь", customer:"ФГБУ ФНКЦ ФИЗИКО-ХИМИЧЕСКОЙ МЕДИЦИНЫ"},
        {name:"АО \"РОЛЬФ\"", sum:9391375, region:"Ленинградская Область", category:"Автотранспорт легковой, автобусы", status:"Исполнение", date:"2026-02-24", brandHint:"Haval, Kia", customer:"МКУ \"ТРАНСПОРТНО - ХОЗЯЙСТВЕННАЯ ЭКСПЛУАТАЦИОННАЯ СЛУЖБА\""},
        {name:"АО \"РОЛЬФ\"", sum:4949998.02, region:"Свердловская Область", category:"Автотранспорт легковой, автобусы", status:"Исполнение", date:"2026-03-03", brandHint:"Geely", customer:"ГКУ СО \"ХОЗЯЙСТВЕННО-ЭКСПЛУАТАЦИОННОЕ УПРАВЛЕНИЕ МИНИСТЕРСТВА ОБРАЗОВАНИЯ\""},
        {name:"АО \"РОЛЬФ\"", sum:4040000, region:"Карелия Республика", category:"Автотранспорт легковой, автобусы", status:"Контракт заключен", date:"2026-04-03", brandHint:"Haval", customer:"МБУ Петрозаводского ГО \"ХОЗЯЙСТВЕННО-ЭКСПЛУАТАЦИОННАЯ СЛУЖБА\""},
        {name:"АО \"РОЛЬФ\"", sum:2618595, region:"Ленинградская Область", category:"Автотранспорт легковой, автобусы", status:"Исполнение", date:"2026-04-06", brandHint:"Haval", customer:"ГКУ ЛО \"ДИРЕКЦИЯ ДОРОЖНОГО СТРОИТЕЛЬСТВА\""},
        {name:"ООО \"ВМ-Н-АЗИЯ\"", sum:15895551.36, region:"Хабаровский Край", category:"Автотранспорт легковой, автобусы", status:"Исполнение", date:"2026-04-07", brandHint:"Haval, Geely", customer:"КГКУ \"АВТОБАЗА ПРАВИТЕЛЬСТВА ХАБАРОВСКОГО КРАЯ\""},
        {name:"ООО \"АВТОЛЮКС-ВОРОНЕЖ\"", sum:5022345, region:"Пензенская Область", category:"Автотранспорт легковой, автобусы", status:"Исполнение завершено", date:"2026-03-23", brandHint:"Haval H9", customer:"ГБУ \"УПРАВЛЕНИЕ ДЕЛАМИ ГУБЕРНАТОРА И ПРАВИТЕЛЬСТВА ПЕНЗЕНСКОЙ ОБЛАСТИ\""}
    ];

    // Фильтруем легковые категории
    let contracts = rawContracts.filter(c => 
        c.category.includes("Автотранспорт легковой") || 
        c.category === "Спецтранспорт" ||
        c.category.includes("Спецтранспорт") ||
        c.category === "Автотранспорт легковой, автобусы"
    );
    
    // Функция определения бренда
    function getBrand(contract) {
        let text = (contract.brandHint || "").toLowerCase();
        if (contract.name.includes("ЛАДА-СЕРВИС")) return "LADA";
        if (contract.name.includes("РОЛЬФ")) return "Haval / Kia / Geely";
        if (contract.name.includes("АВИЛОН")) return "BMW / Haval / Mercedes";
        if (text.includes("haval")) return "Haval";
        if (text.includes("lada")) return "LADA";
        if (text.includes("kia")) return "Kia";
        if (text.includes("гели") || text.includes("geely")) return "Geely";
        if (text.includes("скорая")) return "Спецтранспорт (Скорая)";
        if (contract.category.includes("Спецтранспорт")) return "Спецтехника / Автоцистерны";
        return "Другие марки";
    }

    contracts = contracts.map(c => ({ ...c, brand: getBrand(c), sumMln: c.sum / 1e6, customerShort: c.customer || "Государственный заказчик" }));

    // Фильтрация
    function applyFilters() {
        let region = document.getElementById("regionFilter").value;
        let category = document.getElementById("categoryFilter").value;
        let status = document.getElementById("statusFilter").value;
        return contracts.filter(c => 
            (region === "all" || c.region === region) &&
            (category === "all" || c.category === category) &&
            (status === "all" || c.status === status)
        );
    }

    // Отрисовка всего дашборда
    function renderDashboard() {
        const filtered = applyFilters();
        const totalSumMln = filtered.reduce((acc, c) => acc + c.sumMln, 0);
        const totalContracts = filtered.length;
        const uniqueSuppliers = new Set(filtered.map(c => c.name)).size;
        const rolefSum = filtered.filter(c => c.name.includes("РОЛЬФ")).reduce((s,c) => s + c.sumMln,0);
        
        document.getElementById("kpiContainer").innerHTML = `
            <div class="kpi-card"><div class="kpi-title"><i class="fas fa-chart-line"></i> Объем рынка (легковые)</div><div class="kpi-value">${totalSumMln.toFixed(1)} млн ₽</div><div class="kpi-sub">${totalContracts} контрактов</div></div>
            <div class="kpi-card"><div class="kpi-title"><i class="fas fa-car-side"></i> Участники</div><div class="kpi-value">${uniqueSuppliers}</div><div class="kpi-sub">поставщиков</div></div>
            <div class="kpi-card"><div class="kpi-title"><i class="fas fa-chart-simple"></i> Доля РОЛЬФ</div><div class="kpi-value">${(totalSumMln > 0 ? (rolefSum/totalSumMln*100).toFixed(1) : 0)}%</div><div class="kpi-sub">сумма: ${rolefSum.toFixed(1)} млн ₽</div></div>
            <div class="kpi-card"><div class="kpi-title"><i class="fas fa-chart-pie"></i> Средняя цена лота</div><div class="kpi-value">${(totalSumMln/totalContracts || 0).toFixed(1)} млн</div><div class="kpi-sub">по фильтру</div></div>
        `;
        
        // ТОП поставщиков
        const supMap = new Map();
        filtered.forEach(c => {
            let old = supMap.get(c.name) || {sum:0, count:0, regions: new Set()};
            old.sum += c.sumMln;
            old.count += 1;
            old.regions.add(c.region);
            supMap.set(c.name, old);
        });
        let topSuppliers = Array.from(supMap.entries()).map(([name, data]) => ({name, sum: data.sum, count: data.count, regions: Array.from(data.regions).slice(0,2).join(", ") })).sort((a,b)=>b.sum - a.sum).slice(0,6);
        
        const ctxSup = document.getElementById('supplierChart').getContext('2d');
        if(window.supplierChartInstance) window.supplierChartInstance.destroy();
        window.supplierChartInstance = new Chart(ctxSup, { type: 'bar', data: { labels: topSuppliers.map(s=>s.name.length>20?s.name.slice(0,18)+'…':s.name), datasets: [{ label: 'млн ₽', data: topSuppliers.map(s=>s.sum), backgroundColor: '#3173a3', borderRadius: 8 }] } });
        
        // Бренды
        const brandAgg = new Map();
        filtered.forEach(c => brandAgg.set(c.brand, (brandAgg.get(c.brand)||0) + c.sumMln));
        let brandData = Array.from(brandAgg.entries()).sort((a,b)=>b[1]-a[1]).slice(0,5);
        const ctxBrand = document.getElementById('brandChart').getContext('2d');
        if(window.brandChartInstance) window.brandChartInstance.destroy();
        window.brandChartInstance = new Chart(ctxBrand, { type: 'bar', data: { labels: brandData.map(b=>b[0]), datasets: [{ label: 'Объем спроса, млн ₽', data: brandData.map(b=>b[1]), backgroundColor: '#4f8bc9' }] } });
        
        // Регионы
        const regionMap = new Map();
        filtered.forEach(c => regionMap.set(c.region, (regionMap.get(c.region)||0) + c.sumMln));
        let topRegions = Array.from(regionMap.entries()).sort((a,b)=>b[1]-a[1]).slice(0,6);
        const ctxReg = document.getElementById('regionChart').getContext('2d');
        if(window.regionChartInstance) window.regionChartInstance.destroy();
        window.regionChartInstance = new Chart(ctxReg, { type: 'bar', data: { labels: topRegions.map(r=>r[0]), datasets: [{ label: 'млн ₽', data: topRegions.map(r=>r[1]), backgroundColor: '#5c9c6e' }] } });
        
        // Динамика
        const monthMap = new Map();
        filtered.forEach(c => { let m = dayjs(c.date).format('MMM YY'); monthMap.set(m, (monthMap.get(m)||0) + c.sumMln); });
        let monthsSorted = Array.from(monthMap.keys()).sort((a,b)=> dayjs(a,'MMM YY') - dayjs(b,'MMM YY'));
        const ctxTime = document.getElementById('timelineChart').getContext('2d');
        if(window.timeChartInstance) window.timeChartInstance.destroy();
        window.timeChartInstance = new Chart(ctxTime, { type: 'line', data: { labels: monthsSorted, datasets: [{ label: 'Сумма контрактов, млн ₽', data: monthsSorted.map(m=>monthMap.get(m)), borderColor: '#e68a2e', tension: 0.2, fill: false }] } });
        
        // Таблица поставщиков
        let supplierHtml = '';
        topSuppliers.forEach(sup => {
            let isRolef = sup.name.includes("РОЛЬФ");
            supplierHtml += `<tr ${isRolef ? 'style="background:#FEF6E0;"' : ''}><td><strong>${sup.name}</strong> ${isRolef ? '<span class="badge-win">Наша компания</span>' : ''}</td>
            <td>${sup.sum.toFixed(1)}</td><td>${sup.count}</td><td>${sup.regions || '—'}</td>
            <td>${sup.name.includes("ЛАДА-СЕРВИС") ? "Соцобеспечение, LADA" : sup.name.includes("ПРОФАВТО") ? "Медицина (скорые)" : sup.name.includes("РОЛЬФ") ? "Китайские бренды, лизинг" : "Разные бренды"}</td></tr>`;
        });
        document.querySelector("#supplierTable tbody").innerHTML = supplierHtml;

        // ----- НОВАЯ ТАБЛИЦА ЗАКАЗЧИКОВ (ТОП-10 по сумме) -----
        const customerMap = new Map(); // ключ - имя заказчика, храним сумму, поставщика, бренд, регион
        filtered.forEach(c => {
            let cust = c.customerShort;
            let old = customerMap.get(cust) || { sum: 0, supplier: c.name, brand: c.brand, region: c.region, count: 0 };
            old.sum += c.sumMln;
            old.count += 1;
            // обновляем поставщика, если по сумме не принципиально, но для таблицы берем поставщика самого крупного контракта (упрощенно: последний)
            old.supplier = c.name;
            old.brand = c.brand;
            old.region = c.region;
            customerMap.set(cust, old);
        });
        let topCustomers = Array.from(customerMap.entries()).map(([name, data]) => ({ name, sum: data.sum, supplier: data.supplier, brand: data.brand, region: data.region }))
            .sort((a,b)=>b.sum - a.sum).slice(0,10);
        
        let customerHtml = '';
        topCustomers.forEach(cust => {
            let isRolefWinner = cust.supplier.includes("РОЛЬФ");
            customerHtml += `<tr>
                <td><strong>${cust.name.length > 55 ? cust.name.slice(0,52)+'…' : cust.name}</strong></td>
                <td>${cust.sum.toFixed(1)} млн ₽</td>
                <td><span class="badge-win" style="background:#e9f0f9;">${cust.brand}</span></td>
                <td>${cust.supplier} ${isRolefWinner ? '<i class="fas fa-check-circle" style="color:#2a7f3e;"></i>' : ''}</td>
                <td>${cust.region}</td>
            </tr>`;
        });
        document.querySelector("#customerTable tbody").innerHTML = customerHtml;
    }

    // Инициализация фильтров
    function populateFilters() {
        let regions = [...new Set(contracts.map(c=>c.region))].sort();
        let categories = [...new Set(contracts.map(c=>c.category))];
        let statuses = [...new Set(contracts.map(c=>c.status))];
        document.getElementById("regionFilter").innerHTML = '<option value="all">Все регионы</option>' + regions.map(r=>`<option value="${r}">${r}</option>`).join('');
        document.getElementById("categoryFilter").innerHTML = '<option value="all">Все категории</option>' + categories.map(c=>`<option value="${c}">${c}</option>`).join('');
        document.getElementById("statusFilter").innerHTML = '<option value="all">Все статусы</option>' + statuses.map(s=>`<option value="${s}">${s}</option>`).join('');
    }

    document.getElementById("regionFilter").addEventListener("change", () => renderDashboard());
    document.getElementById("categoryFilter").addEventListener("change", () => renderDashboard());
    document.getElementById("statusFilter").addEventListener("change", () => renderDashboard());
    document.getElementById("resetFilters").addEventListener("click", () => {
        document.getElementById("regionFilter").value = "all";
        document.getElementById("categoryFilter").value = "all";
        document.getElementById("statusFilter").value = "all";
        renderDashboard();
    });
    
    populateFilters();
    renderDashboard();
</script>
</body>
</html>
