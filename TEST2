        {name:"ООО ТОРГОВЫЙ ДОМ \"АВТОГРЕЙ\"", sum:79275000, region:"Москва Город", category:"Спецтехника", status:"Исполнение", date:"2026-04-06", brandHint:"Пожарные", customer:"ФЕДЕРАЛЬНАЯ СЛУЖБА ИСПОЛНЕНИЯ НАКАЗАНИЙ"},
